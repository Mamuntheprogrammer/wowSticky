<Window x:Class="WowSticky.Windows.NoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        Width="280" Height="360" ResizeMode="NoResize"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="NoteButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Bd" Background="Transparent"
                                CornerRadius="4" Padding="0"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Width="26" Height="26">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#20FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DropShadowEffect x:Key="ShadowEffect" BlurRadius="24" Opacity="0.35"
                          ShadowDepth="4" Direction="315" Color="#000000"/>
    </Window.Resources>

    <Border Name="NoteBorder" CornerRadius="12" Padding="0"
            BorderThickness="1" BorderBrush="Transparent"
            Effect="{StaticResource ShadowEffect}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#0A000000"
                    CornerRadius="12,12,0,0" Padding="6,4"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid MinHeight="30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="2,0,0,0">
                        <Button Name="PinBtn" Content="📌" ToolTip="Pin note"
                                Style="{StaticResource NoteButton}" Click="Pin_Click"/>
                        <Button Name="LockBtn" Content="🔒" ToolTip="Lock note"
                                Style="{StaticResource NoteButton}" Click="Lock_Click"/>
                    </StackPanel>

                     <Grid Grid.Column="1" Margin="4,0">
                         <TextBlock Name="TitlePlaceholder" Text="Untitled"
                                    FontSize="12" FontWeight="SemiBold"
                                    Opacity="0.4"
                                    IsHitTestVisible="False"
                                    VerticalAlignment="Center"
                                    Padding="4,2" Margin="0"/>
                         <TextBox Name="TitleBox"
                                  FontSize="12" FontWeight="SemiBold"
                                  Background="Transparent" BorderThickness="0"
                                  TextChanged="Title_Changed"
                                  VerticalAlignment="Center"
                                  Padding="4,2"/>
                     </Grid>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Name="ColorBtn" Content="🎨" ToolTip="Change color"
                                Style="{StaticResource NoteButton}" Click="Color_Click"/>
                        <Button Name="FontDownBtn" Content="−" ToolTip="Decrease font"
                                Style="{StaticResource NoteButton}" Click="FontDown_Click"/>
                        <TextBlock Name="FontSizeLabel" Text="14" FontSize="10"
                                   VerticalAlignment="Center" Margin="1,0" Opacity="0.6"/>
                        <Button Name="FontUpBtn" Content="+" ToolTip="Increase font"
                                Style="{StaticResource NoteButton}" Click="FontUp_Click"/>
                        <Button Name="TrashBtn" Content="🗑" ToolTip="Trash note"
                                Style="{StaticResource NoteButton}" Click="Trash_Click"/>
                        <Button Name="AlwaysOnTopBtn" Content="📌" ToolTip="Always on top"
                                Style="{StaticResource NoteButton}" Click="AlwaysOnTop_Click"/>
                        <Button Name="MinBtn" Content="─" ToolTip="Minimize"
                                Style="{StaticResource NoteButton}" Click="Minimize_Click"/>
                        <Button Name="CloseBtn" Content="✕" ToolTip="Close"
                                Style="{StaticResource NoteButton}" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <TextBox Name="ContentBox" Grid.Row="1"
                     FontSize="14" Padding="16,12"
                     Background="Transparent" BorderThickness="0"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     TextChanged="Content_Changed"/>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#0A000000"
                    CornerRadius="0,0,12,12" Padding="12,4"
                    MouseLeftButtonDown="Footer_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Name="DateLabel" Grid.Column="0" FontSize="10" Opacity="0.4"/>
                    <TextBlock Name="TitleLabel" Grid.Column="1" FontSize="10" Opacity="0.4"/>
                </Grid>
            </Border>

            <!-- Resize Edges -->
            <Thumb Name="ResizeTop" Grid.RowSpan="3"
                   Cursor="SizeNS"
                   VerticalAlignment="Top" Height="6"
                   HorizontalAlignment="Stretch"
                   DragDelta="ResizeTop_DragDelta" IsTabStop="False">
                <Thumb.Template>
                    <ControlTemplate>
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
            <Thumb Name="ResizeBottom" Grid.RowSpan="3"
                   Cursor="SizeNS"
                   VerticalAlignment="Bottom" Height="6"
                   HorizontalAlignment="Stretch"
                   DragDelta="ResizeBottom_DragDelta" IsTabStop="False">
                <Thumb.Template>
                    <ControlTemplate>
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
            <Thumb Name="ResizeLeft" Grid.RowSpan="3"
                   Cursor="SizeWE"
                   HorizontalAlignment="Left" Width="6"
                   VerticalAlignment="Stretch"
                   DragDelta="ResizeLeft_DragDelta" IsTabStop="False">
                <Thumb.Template>
                    <ControlTemplate>
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
            <Thumb Name="ResizeRight" Grid.RowSpan="3"
                   Cursor="SizeWE"
                   HorizontalAlignment="Right" Width="6"
                   VerticalAlignment="Stretch"
                   DragDelta="ResizeRight_DragDelta" IsTabStop="False">
                <Thumb.Template>
                    <ControlTemplate>
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>

            <!-- Resize Corners -->
            <Thumb Name="ResizeTopLeft" Grid.RowSpan="3"
                   Cursor="SizeNWSE"
                   VerticalAlignment="Top" HorizontalAlignment="Left"
                   Width="10" Height="10"
                   DragDelta="ResizeTopLeft_DragDelta" IsTabStop="False">
                <Thumb.Template>
                    <ControlTemplate>
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
            <Thumb Name="ResizeTopRight" Grid.RowSpan="3"
                   Cursor="SizeNESW"
                   VerticalAlignment="Top" HorizontalAlignment="Right"
                   Width="10" Height="10"
                   DragDelta="ResizeTopRight_DragDelta" IsTabStop="False">
                <Thumb.Template>
                    <ControlTemplate>
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
            <Thumb Name="ResizeBottomLeft" Grid.RowSpan="3"
                   Cursor="SizeNESW"
                   VerticalAlignment="Bottom" HorizontalAlignment="Left"
                   Width="10" Height="10"
                   DragDelta="ResizeBottomLeft_DragDelta" IsTabStop="False">
                <Thumb.Template>
                    <ControlTemplate>
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
            <Thumb Name="ResizeBottomRight" Grid.RowSpan="3"
                   Cursor="SizeNWSE"
                   VerticalAlignment="Bottom" HorizontalAlignment="Right"
                   Width="10" Height="10"
                   DragDelta="ResizeBottomRight_DragDelta" IsTabStop="False">
                <Thumb.Template>
                    <ControlTemplate>
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
        </Grid>
    </Border>
</Window>
