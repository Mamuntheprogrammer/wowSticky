<Window x:Class="WowSticky.Windows.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        Width="380" Height="320" WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Border CornerRadius="16" Background="#1A1A2E"
            BorderThickness="1" BorderBrush="#2A2A4E"
            Padding="28,24">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" Opacity="0.5"
                              ShadowDepth="6" Direction="315" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="About WowSticky"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#FFFFFF" TextAlignment="Center"
                       Margin="0,0,0,12"/>

            <Border Grid.Row="1" Background="#14FFFFFF" CornerRadius="12"
                    Padding="20,16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontSize="13" Foreground="#C0C0D8" Margin="0,0,0,8"
                               TextAlignment="Center">
                        WowSticky v1.1<LineBreak/>
                        A sticky-note app that follows<LineBreak/>
                        folders in Windows Explorer.
                    </TextBlock>
                    <Separator Background="#2A2A4E" Margin="0,6"/>
                    <TextBlock FontSize="12" Foreground="#8888AA" Margin="0,4,0,2">
                        Developer:
                        <Run FontWeight="SemiBold" Foreground="#C0C0D8"
                             Text="Md. Abdullah Al Mamun"/>
                    </TextBlock>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="12" Foreground="#8888AA"
                                   VerticalAlignment="Center">
                            Email: <Run Foreground="#C0C0D8" Text="a.a.mamunbu@gmail.com"/>
                        </TextBlock>
                        <Button Grid.Column="1" Content="Copy" FontSize="10"
                                Foreground="#6366F1" Background="Transparent"
                                BorderThickness="0" Cursor="Hand"
                                Padding="8,4" Click="CopyEmail_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Name="Bd" Background="Transparent"
                                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#14FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                    <Separator Background="#2A2A4E" Margin="0,6"/>
                    <TextBlock FontSize="12" Margin="0,2">
                        <Hyperlink Name="LinkedInLink" NavigateUri="https://www.linkedin.com/in/mamuntheprogrammer"
                                   RequestNavigate="Link_RequestNavigate"
                                   Foreground="#6366F1" TextDecorations="None">
                            LinkedIn
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock FontSize="12" Margin="0,4,0,0">
                        <Hyperlink Name="GitHubLink" NavigateUri="https://github.com/Mamuntheprogrammer"
                                   RequestNavigate="Link_RequestNavigate"
                                   Foreground="#6366F1" TextDecorations="None">
                            GitHub
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Button Grid.Row="2" Content="Close"
                    FontSize="13" FontWeight="SemiBold"
                    Foreground="#FFFFFF" Cursor="Hand"
                    HorizontalAlignment="Center" Padding="32,8"
                    Click="Close_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Bd" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#6366F1" Offset="0.0"/>
                                    <GradientStop Color="#8B5CF6" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>